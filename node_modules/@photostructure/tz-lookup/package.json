{
  "name": "@photostructure/tz-lookup",
  "version": "11.6.0",
  "description": "fast time zone lookup",
  "keywords": [
    "timezone",
    "time zone",
    "tz",
    "latitude",
    "longitude",
    "coordinates",
    "geolocation",
    "geo",
    "iana"
  ],
  "license": "CC0-1.0",
  "author": {
    "email": "tzlookup@photostructure.com",
    "name": "PhotoStructure, Inc."
  },
  "main": "tz.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "mocha",
    "prettier": "prettier --write package.json test.js tz_template.js pack.js",
    "install:pinact": "go install github.com/suzuki-shunsuke/pinact/v3/cmd/pinact@latest",
    "update": "npm-check-updates --upgrade --install always && pinact run -u "
  },
  "devDependencies": {
    "geo-tz": "^8.1.7",
    "inhabited": "^2.0.3",
    "luxon": "^3.7.2",
    "mocha": "^11.7.6",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.8.1",
    "uglify-js": "^3.19.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/photostructure/tz-lookup.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
